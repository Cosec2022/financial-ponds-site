  "graph_adaptation": {
    "schema_version": "adaptive_graph_feedback_v1",
    "principle": "Industry upstream/downstream nodes are model parameters, not permanent truth. News feedback and hard market confirmation can raise, lower, add, or archive nodes.",
    "update_modes": [
      {
        "id": "daily_light",
        "name": "每日轻量反馈",
        "description": "不用GPT。用新闻命中、ETF价格/成交/份额和行业相对强弱更新节点 evidence_count、miss_count、confidence 和建议动作。"
      },
      {
        "id": "weekly_llm_review",
        "name": "每周GPT审计",
        "description": "只审计节点和关键词是否仍有效，输出 add/adjust/archive proposals；不直接给交易结论。"
      },
      {
        "id": "manual_override",
        "name": "人工覆盖",
        "description": "前端可临时调整权重并导出 patch JSON；正式生效应写入 config/graph_overrides。"
      }
    ],
    "proposal_files": [
      "model_outputs/<date>/graph_feedback_proposals.json",
      "model_outputs/<week>/weekly_graph_review.json",
      "config/graph_overrides/manual_overrides.json"
