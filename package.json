{
  "name": "financial-ponds-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bash scripts/build.sh",
    "validate": "node scripts/validate-artifact.mjs",
    "validate:data": "node scripts/validate-published-data.mjs",
    "test": "node --test tests/*.test.mjs",
    "preview": "npm run build && node scripts/preview.mjs",
    "deploy": "npm run build && npx wrangler@4.102.0 deploy",
    "fp:daily": "bash scripts/local/fp-daily.sh",
    "fp:today": "bash scripts/local/fp-today-full-update.sh",
    "fp:summary": "node scripts/local/fp-progress-summary.mjs"
  },
  "devDependencies": {
    "wrangler": "4.102.0"
  },
  "version": "0.10.56"
}
