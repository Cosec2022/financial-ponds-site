{
  "name": "financial-ponds-site",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bash scripts/build.sh",
    "build:data": "npm run fp:daily",
    "build:site": "bash scripts/build-site.sh",
    "validate": "node scripts/validate-artifact.mjs",
    "validate:data": "node scripts/validate-published-data.mjs",
    "test": "node --test tests/*.test.mjs",
    "preview": "npm run build && node scripts/preview.mjs",
    "deploy": "npm run build:site && npx wrangler@4.102.0 deploy",
    "fp:daily": "bash scripts/local/fp-daily.sh",
    "fp:research": "node scripts/build-market-penetration-ai.mjs",
    "fp:backfill": "node scripts/local/fp-backfill.mjs",
    "fp:today": "bash scripts/local/fp-today-full-update.sh",
    "fp:summary": "node scripts/local/fp-progress-summary.mjs",
    "benchmark:archive": "node scripts/apply-benchmark-to-archives.mjs",
    "history:snapshot": "node scripts/build-daily-longitudinal-archive.mjs",
    "history:labels": "node scripts/build-daily-outcome-label-ledger.mjs",
    "history:coverage": "node scripts/history-cli.mjs coverage",
    "history:inspect": "node scripts/history-cli.mjs inspect",
    "history:compare": "node scripts/history-cli.mjs compare",
    "history:import-committed": "node scripts/import-committed-historical-snapshots.mjs"
  },
  "devDependencies": {
    "wrangler": "4.102.0"
  },
  "version": "0.10.75"
}
