      "layer": "confirmation",
      "channel": "sector_confirmation",
      "direction": "positive",
      "weight": 0.2,
      "transform": "identity",
      "description": "Sector performance relative to broad A-shares or CSI 300."
    },
    {
      "suffix": "breadth",
      "name_suffix": "Breadth",
      "data_type": "hard_data",
      "category": "sector_confirmation",
      "frequency": "daily",
      "layer": "confirmation",
      "channel": "sector_confirmation",
      "direction": "positive",
      "weight": 0.15,
