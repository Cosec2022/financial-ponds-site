{
  "version": "0.8.0",
  "reviewed_at": "2026-07-02",
  "purpose": "Open-source provider candidates for A-share industry ETF and S&P 500 ETF data ingestion. Provider adapters must stay outside the core graph engine.",
  "core_boundary": {
    "core_must_not_import_providers": true,
    "provider_output_contract": "raw snapshots plus local CSV or JSON exports that become node observations through collectors",
    "default_enabled": false
  },
  "candidates": [
    {
      "id": "akshare",
      "priority": 1,
      "role": "primary_a_share_etf_provider",
      "repo_url": "https://github.com/akfamily/akshare",
      "docs_url": "https://akshare.akfamily.xyz/data/fund/fund_public.html",
      "language": "python",
      "token_required": false,
      "license_observed": "MIT",
      "default_status": "bridge_fixture_ready_real_optional_scale_warning_added_disabled",
      "best_for": [
        "a_share_etf_spot",
        "a_share_etf_history",
        "a_share_etf_share_scale",
        "china_public_market_reference_data"
      ],
      "not_for": [
        "direct_core_scoring",
        "unverified_live_trading",
        "single_source_final_decision"
      ],
      "planned_adapter": "providers/akshare_etf_bridge",
      "validation_command": "npm run provider:akshare:validate",
      "target_exports": [
        "data/provider_exports/a_share_etf_daily.csv",
        "raw_data/provider/akshare/<date>/"
      ],
      "important_endpoints": [
        "fund_etf_spot_em",
        "fund_etf_hist_em",
        "fund_etf_scale_sse",
        "fund_etf_scale_szse",
        "fund_scale_daily_szse"
      ],
      "risk_notes": [
        "Provider interfaces can change or disappear.",
        "Raw output must be stored before normalization.",
        "Schema drift must disable the adapter instead of producing silent scores."
      ]
    },
